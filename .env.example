# Feishu custom app credentials. The app must have permission to read/export
# the target document, and the document must be accessible to the app or token user.
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: use a pre-obtained user/tenant access token instead of app_id/app_secret.
# FEISHU_ACCESS_TOKEN=t-xxxxxxxxxxxxxxxx

# Optional: use https://open.larksuite.com for Lark tenants.
FEISHU_OPEN_BASE_URL=https://open.feishu.cn
